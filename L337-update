#!/bin/sh

# =============================================================================
# L337-update — Pull latest L337-Merlin scripts from GitHub.
#
# Fetches the deployment manifest from the repository, then pulls every file
# listed in it to /jffs/scripts/. Config files are never touched.
#
# Usage: /jffs/scripts/L337-update
#
# Bootstrap (first install, run once from router SSH):
#   curl -fsSL https://raw.githubusercontent.com/jensbrak/L337-Merlin/main/L337-update \
#       -o /jffs/scripts/L337-update && chmod +x /jffs/scripts/L337-update \
#       && /jffs/scripts/L337-update
# =============================================================================

PATH="/sbin:/bin:/usr/sbin:/usr/bin"

LOGTAG="L337-update"

# Repository base URL. This is the single line to change if you are running
# a fork — update 'jensbrak' and/or the repo name to match your fork.
REPO_RAW="https://raw.githubusercontent.com/jensbrak/L337-Merlin/main"

INSTALL_DIR="/jffs/scripts"
CURL="/usr/sbin/curl"

TMP_MANIFEST="/tmp/L337_manifest.$$"

log() { logger -t "$LOGTAG" "$*"; }

cleanup() {
    rm -f "$TMP_MANIFEST"
}
trap cleanup EXIT

if [ ! -x "$CURL" ]; then
    log "curl not found at $CURL; aborting"
    exit 1
fi

# Fetch manifest — this defines what gets deployed.
# To add or remove a script, edit manifest.txt in the repository.
if ! "$CURL" \
        --silent \
        --show-error \
        --fail \
        --connect-timeout 10 \
        --max-time 30 \
        --output "$TMP_MANIFEST" \
        "${REPO_RAW}/manifest.txt" 2>/dev/null; then
    log "Failed to fetch manifest; aborting"
    exit 1
fi

# Parse manifest: strip comments and blank lines.
SCRIPTS="$(grep -v '^\s*#' "$TMP_MANIFEST" 2>/dev/null | grep -v '^\s*$')"

if [ -z "$SCRIPTS" ]; then
    log "Manifest is empty or unreadable; aborting"
    exit 1
fi

ERRORS=0

for SCRIPT in $SCRIPTS; do
    [ -z "$SCRIPT" ] && continue

    URL="${REPO_RAW}/${SCRIPT}"
    DEST="${INSTALL_DIR}/${SCRIPT}"
    TMP="${DEST}.tmp.$$"

    if "$CURL" \
            --silent \
            --show-error \
            --fail \
            --connect-timeout 10 \
            --max-time 30 \
            --output "$TMP" \
            "$URL" 2>/dev/null; then
        mv "$TMP" "$DEST"
        chmod +x "$DEST"
        log "Updated: $SCRIPT"
    else
        rm -f "$TMP"
        log "Failed to fetch: $SCRIPT"
        ERRORS=$((ERRORS + 1))
    fi
done

if [ "$ERRORS" -eq 0 ]; then
    log "All scripts updated successfully"
    exit 0
else
    log "Update completed with $ERRORS error(s)"
    exit 1
fi
